{
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run translate\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "translate": "cd server && node translate.mjs"
  },
  "dependencies": {
    "concurrently": "^9.1.2"
  }
}
