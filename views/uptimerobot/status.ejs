<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Status - Dj Larkiboy Events</title>
    <style nonce="<%= nonce %>">
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
          Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
        line-height: 1.6;
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
        color: #333;
        background-color: #f8f9fa;
      }

      h1 {
        text-align: center;
        margin-bottom: 2rem;
        color: #2c3e50;
      }

      .monitors {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 20px;
      }

      .monitor-card {
        background-color: white;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s ease-in-out;
      }

      .monitor-card:hover {
        transform: translateY(-5px);
      }

      .monitor-name {
        font-size: 1.2rem;
        font-weight: bold;
        margin-bottom: 5px;
      }

      .monitor-url {
        font-size: 0.9rem;
        color: #6c757d;
        margin-bottom: 15px;
        word-break: break-all;
      }

      .status-indicator {
        display: inline-block;
        padding: 8px 12px;
        border-radius: 4px;
        font-weight: bold;
        margin-bottom: 10px;
      }

      .status-up {
        background-color: #d4edda;
        color: #155724;
      }

      .status-down {
        background-color: #f8d7da;
        color: #721c24;
      }

      .status-warning {
        background-color: #fff3cd;
        color: #856404;
      }

      .status-paused {
        background-color: #e2e3e5;
        color: #383d41;
      }

      .status-pending {
        background-color: #d1ecf1;
        color: #0c5460;
      }

      .status-unknown {
        background-color: #e2e3e5;
        color: #383d41;
      }

      .monitor-stats {
        margin-top: 15px;
        font-size: 0.9rem;
      }

      .stats-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
      }

      .uptime {
        display: flex;
        align-items: center;
      }

      .uptime-bar {
        height: 8px;
        width: 100%;
        background-color: #e9ecef;
        border-radius: 4px;
        margin-top: 10px;
        margin-bottom: 15px;
        overflow: hidden;
      }

      .uptime-fill {
        height: 100%;
        background-color: #28a745;
        border-radius: 4px;
      }

      .time-periods {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 15px;
      }

      .time-period {
        background-color: #e9ecef;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
      }

      .refresh-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 2rem 0;
      }

      .last-updated {
        font-size: 0.9rem;
        color: #6c757d;
      }

      .refresh-button {
        background-color: #007bff;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 1rem;
        transition: background-color 0.2s ease-in-out;
      }

      .refresh-button:hover {
        background-color: #0069d9;
      }

      .refresh-button:disabled {
        background-color: #6c757d;
        cursor: not-allowed;
      }

      .return-btn {
        background-color: #1affff;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 1rem;
        transition: background-color 0.2s ease-in-out;
      }

      .return-btn:hover {
        background-color: #16cece;
      }

      .measurement-period {
        background-color: #f1f3f5;
        border-radius: 8px;
        padding: 12px;
        margin-top: 12px;
        font-size: 0.85rem;
      }

      .measurement-title {
        font-weight: bold;
        margin-bottom: 8px;
      }

      .measurement-details {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
      }

      footer {
        margin-top: 3rem;
        text-align: center;
        font-size: 0.9rem;
        color: #6c757d;
      }

      .loading {
        text-align: center;
        padding: 40px;
        font-size: 18px;
        color: #6c757d;
      }

      .loading-spinner {
        border: 4px solid rgba(0, 0, 0, 0.1);
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border-left-color: #007bff;
        animation: spin 1s linear infinite;
        margin: 0 auto 20px;
      }

      @keyframes spin {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }

      .error-message {
        background-color: #f8d7da;
        color: #721c24;
        padding: 15px;
        border-radius: 8px;
        text-align: center;
        margin: 20px 0;
        display: none;
      }
    </style>
  </head>
  <body>
    <h1>Status Dashboard - Dj Larkiboy Events</h1>

    <div class="refresh-section">
      <div class="last-updated">
        Last updated: <span id="last-updated-time">Loading...</span>
        <span id="countdown-timer"></span>
      </div>
      <button class="refresh-button" id="refresh-button">Refresh Status</button>
      <button class="return-btn" id="return-btn">Return Home</button>
    </div>

    <div id="error-message" class="error-message">
      Unable to load monitor data. Please try refreshing the page.
    </div>

    <div id="loading" class="loading">
      <div class="loading-spinner"></div>
      Loading status information...
    </div>

    <div class="monitors" id="monitors-container">
      <!-- Monitor data will be loaded here -->
    </div>

    <footer>
      Powered by
      <img src="/img/uptime-robot-logo.svg" alt="Uptimerobot" height="14" />
      &copy; 2025 Dj Larkiboy Events
    </footer>

    <script nonce="<%= nonce %>">
      // Variables for refresh timer
      const REFRESH_INTERVAL = 30; // seconds
      let refreshTimeoutId = null;
      let countdownIntervalId = null;
      let isRefreshing = false;

      // DOM elements - with null checks
      const monitorsContainer = document.getElementById("monitors-container");
      const loadingElement = document.getElementById("loading");
      const errorElement = document.getElementById("error-message");
      const lastUpdatedElement = document.getElementById("last-updated-time");
      const countdownElement = document.getElementById("countdown-timer");
      const refreshButton = document.getElementById("refresh-button");
      const returnButton = document.getElementById("return-btn");

      // Check if required DOM elements exist
      if (
        !monitorsContainer ||
        !loadingElement ||
        !errorElement ||
        !lastUpdatedElement ||
        !countdownElement ||
        !refreshButton ||
        !returnButton
      ) {
        console.error("Required DOM elements not found");
      }

      // Simplified iframe detection
      function isInIframe() {
        try {
          return window.self !== window.top;
        } catch (e) {
          // Security error indicates we're in a cross-origin iframe
          return true;
        }
      }

      // Hide return button if in iframe
      if (isInIframe() && returnButton) {
        returnButton.style.display = "none";
      }

      // Format dates with error handling
      function formatDate(dateString) {
        try {
          const date = new Date(dateString);
          if (isNaN(date.getTime())) {
            return "Invalid date";
          }
          return date.toLocaleString();
        } catch (error) {
          console.error("Error formatting date:", error);
          return "Invalid date";
        }
      }

      // Format duration with validation
      function formatDuration(duration) {
        if (!duration || typeof duration !== "object") {
          return "0s";
        }

        let result = "";
        if (duration.days > 0) result += `${duration.days}d `;
        if (duration.hours > 0) result += `${duration.hours}h `;
        if (duration.minutes > 0) result += `${duration.minutes}m `;
        if (duration.seconds > 0) result += `${duration.seconds}s`;
        return result.trim() || "0s";
      }

      // Clear all timers
      function clearAllTimers() {
        if (refreshTimeoutId) {
          clearTimeout(refreshTimeoutId);
          refreshTimeoutId = null;
        }
        if (countdownIntervalId) {
          clearInterval(countdownIntervalId);
          countdownIntervalId = null;
        }
      }

      // Fetch monitor data from API
      async function fetchMonitorData() {
        if (isRefreshing) return;

        isRefreshing = true;

        // Clear existing timers
        clearAllTimers();

        // Update UI
        if (loadingElement) loadingElement.style.display = "block";
        if (errorElement) errorElement.style.display = "none";
        if (refreshButton) refreshButton.disabled = true;
        if (countdownElement) countdownElement.textContent = "";

        try {
          const response = await fetch("/status/api/monitors");

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }

          const data = await response.json();

          // Validate response structure
          if (!data || !Array.isArray(data.monitors)) {
            throw new Error("Invalid response format");
          }

          displayMonitorData(data);
          startCountdownTimer();
        } catch (error) {
          console.error("Error fetching monitor data:", error);
          if (loadingElement) loadingElement.style.display = "none";
          if (errorElement) {
            errorElement.style.display = "block";
            errorElement.textContent = `Unable to load monitor data: ${error.message}`;
          }
          // Still start countdown timer to retry
          startCountdownTimer();
        } finally {
          isRefreshing = false;
          if (refreshButton) refreshButton.disabled = false;
        }
      }

      // Display monitor data with validation
      function displayMonitorData(data) {
        if (!monitorsContainer) return;

        // Clear existing monitors
        monitorsContainer.innerHTML = "";

        // Validate monitors array
        if (!data.monitors || !Array.isArray(data.monitors)) {
          console.error("Invalid monitors data");
          return;
        }

        // Create and append monitor cards
        data.monitors.forEach((monitor, index) => {
          try {
            const monitorCard = document.createElement("div");
            monitorCard.className = "monitor-card";

            // Validate monitor data
            const name = monitor.name || `Monitor ${index + 1}`;
            const url = monitor.url || "Unknown URL";
            const status = monitor.status || "Unknown";
            const statusClass = monitor.statusClass || "status-unknown";
            const lastDowntime = monitor.lastDowntime || "Never";

            // Safely get uptime percentage
            const uptimePercentage = monitor.uptime?.uptimePercentage
              ? parseFloat(monitor.uptime.uptimePercentage)
              : 0;

            // Create HTML structure for the monitor card
            monitorCard.innerHTML = `
              <div class="monitor-name">${escapeHtml(name)}</div>
              <div class="monitor-url">${escapeHtml(url)}</div>
              <div class="status-indicator ${statusClass}">
                ${escapeHtml(status)}
              </div>

              <div class="uptime-bar">
                <div class="uptime-fill"></div>
              </div>

              <div class="monitor-stats">
                <div class="stats-row">
                  <div><strong>Uptime:</strong> ${uptimePercentage.toFixed(3)}%</div>
                  <div><strong>Last down:</strong> ${escapeHtml(lastDowntime)}</div>
                </div>

                <div class="stats-row">
                  <div><strong>Uptime duration:</strong> ${formatDuration(monitor.uptime?.statistics?.uptimeDuration)}</div>
                  <div><strong>Downtime duration:</strong> ${formatDuration(monitor.uptime?.statistics?.downtimeDuration)}</div>
                </div>
              </div>

              ${
                monitor.uptime?.measurementPeriod
                  ? `
                <div class="measurement-period">
                  <div class="measurement-title">Measurement Period</div>
                  <div class="measurement-details">
                    <div><strong>Start:</strong> ${formatDate(monitor.uptime.measurementPeriod.startDate)}</div>
                    <div><strong>End:</strong> ${formatDate(monitor.uptime.measurementPeriod.endDate)}</div>
                    <div><strong>Total Duration:</strong> ${formatDuration(monitor.uptime.measurementPeriod.totalDuration)}</div>
                    <div><strong>Monitored:</strong> ${formatDuration(monitor.uptime.measurementPeriod.monitoredDuration)}</div>
                    <div><strong>Paused:</strong> ${formatDuration(monitor.uptime.measurementPeriod.pausedDuration)}</div>
                  </div>
                </div>
              `
                  : ""
              }
            `;

            // Set uptime bar width
            const uptimeFill = monitorCard.querySelector(".uptime-fill");
            if (uptimeFill) {
              uptimeFill.style.width = `${Math.max(0, Math.min(100, uptimePercentage))}%`;
            }

            monitorsContainer.appendChild(monitorCard);
          } catch (error) {
            console.error(
              `Error creating monitor card for monitor ${index}:`,
              error,
            );
          }
        });

        // Update last updated time
        if (lastUpdatedElement) {
          lastUpdatedElement.textContent =
            data.lastUpdated || new Date().toLocaleString();
        }

        // Hide loading element
        if (loadingElement) {
          loadingElement.style.display = "none";
        }
      }

      // Simple HTML escaping
      function escapeHtml(text) {
        const div = document.createElement("div");
        div.textContent = text;
        return div.innerHTML;
      }

      // Start countdown timer for next refresh
      function startCountdownTimer() {
        // Clear any existing timers
        clearAllTimers();

        let secondsLeft = REFRESH_INTERVAL;

        // Update countdown display
        function updateCountdown() {
          if (countdownElement) {
            if (secondsLeft > 0) {
              countdownElement.textContent = `(Updating in ${secondsLeft}s)`;
            } else {
              countdownElement.textContent = "(Updating...)";
            }
          }

          secondsLeft--;
        }

        // Start countdown immediately
        updateCountdown();

        // Set interval for countdown updates
        countdownIntervalId = setInterval(() => {
          updateCountdown();

          // Stop countdown when it reaches -1
          if (secondsLeft < -1) {
            clearInterval(countdownIntervalId);
            countdownIntervalId = null;
          }
        }, 1000);

        // Set timeout for next refresh
        refreshTimeoutId = setTimeout(() => {
          fetchMonitorData();
        }, REFRESH_INTERVAL * 1000);
      }

      // Event listeners
      if (refreshButton) {
        refreshButton.addEventListener("click", () => {
          fetchMonitorData();
        });
      }

      if (returnButton) {
        returnButton.addEventListener("click", () => {
          window.location.href = "/";
        });
      }

      // Cleanup on page unload
      window.addEventListener("beforeunload", () => {
        clearAllTimers();
      });

      // Initial data load when page loads
      document.addEventListener("DOMContentLoaded", fetchMonitorData);
    </script>
  </body>
</html>
