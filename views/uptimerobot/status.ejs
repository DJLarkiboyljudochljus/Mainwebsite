<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Status - Dj Larkiboy Events</title>
    <style nonce="<%= nonce %>">
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
          Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
        line-height: 1.6;
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
        color: #333;
        background-color: #f8f9fa;
      }

      h1 {
        text-align: center;
        margin-bottom: 2rem;
        color: #2c3e50;
      }

      .monitors {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
      }

      .monitor-card {
        background-color: white;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s ease-in-out;
      }

      .monitor-card:hover {
        transform: translateY(-5px);
      }

      .monitor-name {
        font-size: 1.2rem;
        font-weight: bold;
        margin-bottom: 5px;
      }

      .monitor-url {
        font-size: 0.9rem;
        color: #6c757d;
        margin-bottom: 15px;
        word-break: break-all;
      }

      .status-indicator {
        display: inline-block;
        padding: 8px 12px;
        border-radius: 4px;
        font-weight: bold;
        margin-bottom: 10px;
      }

      .status-up {
        background-color: #d4edda;
        color: #155724;
      }

      .status-down {
        background-color: #f8d7da;
        color: #721c24;
      }

      .status-warning {
        background-color: #fff3cd;
        color: #856404;
      }

      .status-paused {
        background-color: #e2e3e5;
        color: #383d41;
      }

      .status-pending {
        background-color: #d1ecf1;
        color: #0c5460;
      }

      .status-unknown {
        background-color: #e2e3e5;
        color: #383d41;
      }

      .monitor-stats {
        display: flex;
        justify-content: space-between;
        margin-top: 15px;
        font-size: 0.9rem;
      }

      .uptime {
        display: flex;
        align-items: center;
      }

      .refresh-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 2rem 0;
      }

      .last-updated {
        font-size: 0.9rem;
        color: #6c757d;
      }

      .refresh-button {
        background-color: #007bff;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 1rem;
        transition: background-color 0.2s ease-in-out;
      }

      .refresh-button:hover {
        background-color: #0069d9;
      }

      footer {
        margin-top: 3rem;
        text-align: center;
        font-size: 0.9rem;
        color: #6c757d;
      }
    </style>
  </head>
  <body>
    <h1>Status Dashboard</h1>

    <div class="refresh-section">
      <div class="last-updated">Last updated: <%= lastUpdated %></div>
      <button class="refresh-button">Refresh Status</button>
    </div>

    <div class="monitors">
      <% monitors.forEach(monitor => { %>
      <div class="monitor-card">
        <div class="monitor-name"><%= monitor.name %></div>
        <div class="monitor-url"><%= monitor.url %></div>
        <div class="status-indicator <%= monitor.statusClass %>">
          <%= monitor.status %>
        </div>
        <div class="monitor-stats">
          <div class="uptime">
            <strong>Uptime:</strong>
            <%= monitor.uptime %>%
          </div>
          <div class="last-downtime">
            <strong>Last down:</strong>
            <%= monitor.lastDowntime %>
          </div>
        </div>
      </div>
      <% }); %>
    </div>

    <footer>
      Powered by
      <img src="/img/uptime-robot-logo.svg" alt="Uptimerobot" height="14" />
    </footer>

    <script nonce="<%= nonce %>">
      // Auto-refresh the page every 5 minutes
      setTimeout(() => {
        location.reload();
      }, 30 * 1000);

      document
        .querySelector(".refresh-button")
        .addEventListener("click", () => location.reload());
    </script>
  </body>
</html>
