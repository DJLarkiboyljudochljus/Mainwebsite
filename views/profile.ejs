<form
  action="/user/update/profile"
  method="post"
  enctype="multipart/form-data"
  class="white-bg"
>
  <div class="form-part">
    <label for="name">Name:</label>
    <input
      type="text"
      id="name"
      name="name"
      value="<%= user.name %>"
      required
    />
  </div>
  <div class="form-part">
    <label for="email">Email:</label>
    <input
      type="email"
      id="email"
      name="email"
      value="<%= user.email %>"
      required
    />
  </div>
  <div class="form-part">
    <label for="image">Image:</label>
    <input type="file" id="image" name="image" required />
    <span class="powered-by">
      <span>Powered by</span>
      <img src="/img/cloudinary.jpg" alt="Cloudinary" />
    </span>
  </div>
  <div class="form-part">
    <button type="submit">Update</button>
  </div>
</form>
