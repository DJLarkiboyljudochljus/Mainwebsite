<div class="user-page">

<h2>All Users</h2>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Role</th>
    </tr>
  </thead>
  <tbody>
    <% users.forEach(user => { %>
      <tr>
        <td><%= user.id %></td>
        <td><%= user.name %></td>
        <td><%= user.email.email %></td>
        <td><%= user.phone.phone %></td>
        <td><%= user.role %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

</div>