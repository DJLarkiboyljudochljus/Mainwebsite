<main style="padding: 20px; margin-bottom: 50px;">
  <section class="overview">
    <h1>Welcome, <%= user.name %>!</h1>
    <div class="stats">
      <div>
        <h2>Total Users</h2>
        <p><%= stats.totalUsers.length %></p>
    </div>
  </section>

  <section class="management">
    <h2>Quick Actions</h2>
    <div class="actions">
      <a href="/admin/users/update" class="button">Update a User</a>
      <a href="/admin/rentals" class="button">View Rentals</a>
      <a href="/admin/settings" class="button">Adjust Settings</a>
    </div>
  </section>

  <section class="recent-activity">
    <h2>Recent Activity</h2>
    <ul>
      <% for (let i = activities.length - 1; i >= 0; i--) { %>
      <li>
        <%= activities[i].timestamp.toString().split("+")[0].replace(" GMT", "") %>: <%= activities[i].type %> <%=
        activities[i].url %>. Body: <%= activities[i].body || "No body" %>
      </li>
      <% } %>
    </ul>
  </section>
</main>
