<div class="dashboard-container">
  <aside class="sidebar">
    <h2>Admin Panel</h2>
    <nav class="sidebar-nav">
      <ul>
        <li><a href="/admin/users">User Management</a></li>
        <li><a href="/admin/events">Event Management</a></li>
        <li><a href="/admin/equipment">Equipment Management</a></li>
        <li><a href="/admin/settings">Settings</a></li>
      </ul>
    </nav>
  </aside>
  <main class="main-content">
    <h1>Welcome to the Admin Dashboard</h1>
    <section class="stats">
      <div class="stat-box">
        <h2>Total Users</h2>
        <p><%= users.length %></p>
      </div>
      <div class="stat-box">
        <h2>Upcoming Events</h2>
        <p><%= bookings.length %></p>
      </div>
      <div class="stat-box">
        <h2>Equipment Available</h2>
        <p><%= totalEquipment %></p>
      </div>
    </section>
    <section class="quick-links">
      <h2>Quick Actions</h2>
      <ul>
        <li><a href="/admin/users">Manage Users</a></li>
        <li><a href="/admin/events">Manage Events</a></li>
        <li><a href="/admin/equipment">Manage Equipment</a></li>
      </ul>
    </section>
  </main>
</div>