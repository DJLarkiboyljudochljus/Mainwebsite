<div class="customer-dashboard">
  <h2>Welcome, <%= user.name %></h2>
  <p>Your current balance: $<%= user.balance %></p>

  <section class="orders-section">
    <h3>Your Orders</h3>
    <% if (user.orders.length > 0) { %>
      <ul>
        <% user.orders.forEach(order => { %>
          <li>Order ID: <%= order.id %> | Status: <%= order.status %> | Total: $<%= order.total %></li>
        <% }) %>
      </ul>
    <% } else { %>
      <p>You have no orders yet.</p>
    <% } %>
  </section>

  <section class="support-section">
    <h3>Customer Support</h3>
    <p>If you need assistance, contact us at <a href="mailto:support@djlarkiboy.com">support@djlarkiboy.com</a>.</p>
  </section>

  <section class="profile-section">
    <h3>Account Details</h3>
    <p>Email: <%= user.email.email %></p>
    <p>Join Date: <%= new Date(user.joinDate).toLocaleDateString() %></p>
  </section>
</div>
