<div class="events-page">
  <h2>All Events</h2>

  <table>
    <thead>
      <tr>
        <th>Event Name</th>
        <th>Date</th>
        <th>Location</th>
        <th>Description</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% events.forEach(event => { %>
        <tr>
          <td><%= event.name %></td>
          <td><%= event.date %></td>
          <td><%= event.location %></td>
          <td><%= event.description %></td>
          <td>
            <a href="/admin/events/edit/<%= event._id %>">Edit</a> |
            <a href="/api/events/delete/<%= event._id %>">Delete</a>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>