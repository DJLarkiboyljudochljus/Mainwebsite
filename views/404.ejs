<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Not Found</title>
    <link rel="stylesheet" href="/css/404.css" />
  </head>
  <body class="error-page">
    <div class="sound-wave"></div>
    <div class="error-container">
      <h1 class="error-title">🎧🔦 Lost in the Sound and Lights? 🔦🎧</h1>
      <p class="error-message">Oops! Looks like this page is out of sync.</p>
      <div class="error-actions">
        <a href="/" class="btn">🏠 Back to Homepage</a>
        <a href="/contact" class="btn">📞 Contact Us</a>
        <button class="btn" id="go-back-btn">🡸 Go back</button>
      </div>
      <p class="error-vibes">
        🎶 In the meantime, enjoy some vibes while we find the missing beats! 🎶
      </p>
    </div>
    <button id="play-sound">Play Sound</button>
    <script src="/js/404.js"></script>
  </body>
</html>
