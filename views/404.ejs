<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Not Found</title>
    <link rel="stylesheet" href="/css/404.css" />
    <link rel="prerender" href="/" />
    <link rel="prefetch" href="/contact" />
  </head>
  <body class="error-page">
    <div class="sound-wave"></div>
    <div class="error-container">
      <h1 class="error-title"><%= __("404-title") %></h1>
      <p class="error-message"><%= __("404-message") %></p>
      <div class="error-actions">
        <a href="/" class="btn"><%= __("404-back-home") %></a>
        <a href="/contact" class="btn"><%= __("404-contact") %></a>
        <button class="btn" id="go-back-btn"><%= __("404-back") %></button>
      </div>
      <p class="error-vibes"><%= __("404-vibes") %></p>
    </div>
    <button id="play-sound"><%= __("404-play") %></button>
    <script src="/js/404.js"></script>
  </body>
</html>
