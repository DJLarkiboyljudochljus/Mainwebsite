<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Contact Form Submission</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
        padding: 20px;
      }
      .email-container {
        max-width: 600px;
        background: white;
        margin: 0 auto;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
      }
      .header {
        background: var(--nice-blue);
        padding: 10px;
        text-align: center;
        font-size: 20px;
        font-weight: bold;
      }
      .content {
        padding: 20px;
        font-size: 16px;
        color: #333;
      }
      .footer {
        margin-top: 20px;
        padding: 10px;
        background: #eee;
        text-align: center;
        font-size: 14px;
        color: #666;
      }
      .message-box {
        border-left: 3px solid #1affff;
        padding-left: 10px;
        margin-top: 10px;
        font-style: italic;
        color: #555;
      }
    </style>
  </head>
  <body>
    <div class="email-container">
      <div class="header">DjLarkiboyLjudochLjus</div>

      <div class="content"><%- body %></div>

      <div class="footer">
        This message was sent automatically via an action made by a user on this
        website, if you have any questions, please email
        <a href="mailto:privacy@djlarkiboy.com">privacy@djlarkiboy.com</a> or
        read our <a href="<%= baseUrl %>/privacy-policy">privacy policy</a>.
        <p>
          If you wish to unsubscribe, click
          <a href="<%= baseUrl %>/unsubscribe?email=<%= recipientEmail %>"
            >here</a
          >.
        </p>
      </div>
    </div>
  </body>
</html>
